# AI gateway configuration (server-side only — never exposed to the browser).
# Copy this file to `.env.local` and fill in your provider + key.
#
# The gateway speaks the OpenAI-compatible /chat/completions API, so any of
# these providers work. Switch provider by changing AI_PROVIDER (and the key).
# Without configuration, AI-powered features (generate list, audit) are
# unavailable, but offline features (quick-add parsing, auto-categorize) still
# work with no key.

# Which provider to use: mistral | openai | deepseek | ollama
AI_PROVIDER=mistral

# Model id. Leave blank to use the provider's default
# (mistral-small-latest | gpt-4o-mini | deepseek-chat | llama3.1).
AI_MODEL=mistral-small-latest

# Override the API base URL. Leave blank to use the provider default:
#   mistral  -> https://api.mistral.ai/v1
#   openai   -> https://api.openai.com/v1
#   deepseek -> https://api.deepseek.com/v1
#   ollama   -> http://localhost:11434/v1
AI_BASE_URL=

# API key for the chosen cloud provider. Not needed for local Ollama.
AI_API_KEY=
